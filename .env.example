# Kracked_OS Root Environment Variables
# Copy this file to .env and fill in the values.
# For production, set these in Vercel → Settings → Environment Variables.

# ========================================
# Server-side (Vercel serverless function)
# Used by tools/api/chat.js as NVIDIA proxy
# ========================================
NVIDIA_API_KEY_70B=

# ========================================
# Client-side (exposed to browser bundle)
# Vite requires VITE_ prefix
# ⚠️ Never put secrets here — they end up in the JS bundle
# ========================================
VITE_NVIDIA_API_KEY_70B=
VITE_GROQ_API_KEY=
VITE_OWNER_EMAIL=zarulijam@gmail.com
VITE_ADMIN_EMAILS=zarulijam@gmail.com
